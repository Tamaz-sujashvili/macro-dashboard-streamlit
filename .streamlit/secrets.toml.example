# Copy this TOML into Streamlit Community Cloud:
# App -> Settings -> Secrets
#
# Local use:
# cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#
# Leave unused keys blank. Do not commit real secrets.

FRED_API_KEY = ""
ALPHA_VANTAGE_KEY = ""
BLS_API_KEY = ""
EIA_API_KEY = ""
FMP_API_KEY = ""
CFTC_APP_TOKEN = ""
NASDAQ_API_KEY = ""
CONGRESS_GOV_API_KEY = ""

# The app currently checks both names below in different paths.
# Set both to the same value for deployment safety.
FINNHUB_API_KEY = ""
FINNHUBAPIKEY = ""

# Local-only feature flags. Keep false in hosted/public deployments.
ENABLE_LOCAL_AI_ANALYSIS = false
ENABLE_X_INTELLIGENCE_REFRESH = false
